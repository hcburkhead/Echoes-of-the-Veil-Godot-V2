; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Echoes of the Veil"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

AiManager="*res://managers/AIManager.gd"
DiceManager="*res://managers/DiceManager.gd"
MemoryManager="*res://managers/MemoryManager.gd"
MusicManager="*res://managers/MusicManager.gd"
SaveManager="*res://managers/SaveManager.gd"
SupabaseManager="*res://managers/SupabaseManager.gd"
UiManager="*res://managers/UIManager.gd"
VoiceManager="*res://managers/VoiceManager.gd"
